  "item": [
    {
      "name": "REQ-01 - Criar Pet",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Gera valores aleatórios para testar caminhos felizes e tristes",
              "const idbase = [Math.floor(Math.random() * 10000), Math.floor(Math.random() * 10000), \"string\"];",
              "const namebase = [\"Pet\" + Math.floor(Math.random() * 10000), \"Pet\" + Math.floor(Math.random() * 10000), 1501];",
              "const statusbase = [\"available\", \"pending\", \"sold\", \"error\", 1];",
              "",
              "const indiceIdRNG = Math.floor(Math.random() * idbase.length);",
              "const indiceNameRNG = Math.floor(Math.random() * namebase.length);",
              "const indiceStatusRNG = Math.floor(Math.random() * statusbase.length);",
              "",
              "const meuBody = {",
              "    \"id\": idbase[indiceIdRNG],",
              "    \"name\": namebase[indiceNameRNG],",
              "    \"status\": statusbase[indiceStatusRNG]",
              "};",
              "",
              "pm.collectionVariables.set(\"meuBody\", JSON.stringify(meuBody));",
              "pm.collectionVariables.set(\"petId\", idbase[indiceIdRNG]);",
              "",
              "console.log('[REQ-01 PRE] Body enviado:', meuBody);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "try {",
              "    const meuBody = JSON.parse(pm.collectionVariables.get(\"meuBody\"));",
              "    const idRNG = meuBody.id;",
              "    const nameRNG = meuBody.name;",
              "    const statusRNG = meuBody.status;",
              "    ",
              "    // Define valores válidos",
              "    const statusValidos = [\"available\", \"pending\", \"sold\"];",
              "    ",
              "    // Cenário 1: id é string → API retorna 500 (erro)",
              "    if (typeof idRNG === 'string') {",
              "        pm.test(\"✓ [REQ-01] POST retorna 500 quando id é string\", function () {",
              "            pm.response.to.have.status(500);",
              "        });",
              "    }",
              "    // Cenário 2: status é inválido (não está em [available, pending, sold]) → API retorna 400",
              "    else if (typeof statusRNG === 'number' || !statusValidos.includes(statusRNG)) {",
              "        pm.test(\"⚠ [REQ-01] POST retorna 400 quando status é inválido\", function () {",
              "            pm.response.to.have.status(400);",
              "        });",
              "    }",
              "    // Cenário 3: id é number E status é válido → API retorna 200 (caminho feliz)",
              "    else if (typeof idRNG === 'number' && statusValidos.includes(statusRNG)) {",
              "        pm.test(\"✓ [REQ-01] POST retorna 200 - Body válido\", function () {",
              "            pm.response.to.have.status(200);",
              "        });",
              "        ",
              "        if (pm.response.code === 200) {",
              "            const resposta = pm.response.json();",
              "            ",
              "            pm.test(\"✓ [REQ-01] ID na response é number e corresponde ao enviado\", function () {",
              "                pm.expect(resposta.id).to.be.a('number');",
              "                pm.expect(resposta.id).to.eql(idRNG);",
              "            });",
              "            ",
              "            pm.test(\"✓ [REQ-01] Name na response é string (API converte se necessário)\", function () {",
              "                pm.expect(resposta.name).to.be.a('string');",
              "                // Se enviou number, API converte para string",
              "                const expectedName = typeof nameRNG === 'number' ? nameRNG.toString() : nameRNG;",
              "                pm.expect(resposta.name).to.eql(expectedName);",
              "            });",
              "            ",
              "            pm.test(\"✓ [REQ-01] Status na response é string e válido\", function () {",
              "                pm.expect(resposta.status).to.be.a('string');",
              "                pm.expect(resposta.status).to.eql(statusRNG);",
              "            });",
              "        }",
              "    } else {",
              "        pm.test(\"ℹ [REQ-01] POST comportamento não mapeado - status: \" + pm.response.code, function () {",
              "            pm.expect(pm.response.code).to.be.oneOf([200, 400, 500]);",
              "        });",
              "    }",
              "} catch (e) {",
              "    pm.test(\"✗ [REQ-01] Erro ao processar script\", function () {",
              "        throw new Error('Erro: ' + e.message);",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{{meuBody}}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{basePetURL}}/{{versao}}/pet",
          "host": [
            "{{basePetURL}}"
          ],
          "path": [
            "{{versao}}",
            "pet"
          ]
        }
      },
      "response": []
    },
    {
      "name": "REQ-02 - Buscar Pet Criado",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Alternativa: busca o pet criado ou um pet aleatório",
              "const petId = pm.collectionVariables.get(\"petId\");",
              "",
              "if (!petId || typeof petId === 'undefined') {",
              "    console.warn('[REQ-02 PRE] Aviso: petId não definido, usando ID padrão 2');",
              "    pm.collectionVariables.set(\"petIdGet\", 2);",
              "} else {",
              "    const idarraytest = [2, petId];",
              "    const idRNG = Math.floor(Math.random() * idarraytest.length);",
              "    const petIdGet = idarraytest[idRNG];",
              "    pm.collectionVariables.set(\"petIdGet\", petIdGet);",
              "    console.log('[REQ-02 PRE] Buscando pet com ID:', petIdGet);",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "try {",
              "    // Valida se recebeu uma resposta 200",
              "    pm.test(\"✓ [REQ-02] GET retorna status 200\", function () {",
              "        pm.response.to.have.status(200);",
              "    });",
              "    ",
              "    if (pm.response.code === 200) {",
              "        const resposta = pm.response.json();",
              "        const meuBody = JSON.parse(pm.collectionVariables.get(\"meuBody\"));",
              "        const idRNG = meuBody.id;",
              "        const nameRNG = meuBody.name;",
              "        const statusRNG = meuBody.status;",
              "        ",
              "        // Valida tipos de dados",
              "        pm.test(\"✓ [REQ-02] Response ID é number\", function () {",
              "            pm.expect(resposta.id).to.be.a('number');",
              "        });",
              "        ",
              "        pm.test(\"✓ [REQ-02] Response name é string\", function () {",
              "            pm.expect(resposta.name).to.be.a('string');",
              "        });",
              "        ",
              "        pm.test(\"✓ [REQ-02] Response status é string\", function () {",
              "            pm.expect(resposta.status).to.be.a('string');",
              "        });",
              "        ",
              "        // Valida se dados batem com o POST",
              "        const caminhoFeliz = (resposta.id === idRNG && resposta.name === nameRNG && resposta.status === statusRNG);",
              "        ",
              "        if (caminhoFeliz) {",
              "            pm.test(\"✓ [REQ-02] Dados do GET batem com POST\", function () {",
              "                pm.expect(resposta.id).to.eql(idRNG);",
              "                pm.expect(resposta.name).to.eql(nameRNG);",
              "                pm.expect(resposta.status).to.eql(statusRNG);",
              "            });",
              "        } else {",
              "            pm.test(\"⚠ [REQ-02] Dados do GET diferem do POST (era esperado)\", function () {",
              "                pm.expect(resposta).to.have.property('id');",
              "                pm.expect(resposta).to.have.property('name');",
              "                pm.expect(resposta).to.have.property('status');",
              "            });",
              "        }",
              "    }",
              "} catch (e) {",
              "    pm.test(\"✗ [REQ-02] Erro ao processar response\", function () {",
              "        throw new Error('Erro: ' + e.message);",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{basePetURL}}/{{versao}}/pet/{{petIdGet}}",
          "host": [
            "{{basePetURL}}"
          ],
          "path": [
            "{{versao}}",
            "pet",
            "{{petIdGet}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "REQ-03 - Buscar Pet Inexistente",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Alterna entre um ID que pode existir ou não",
              "const arrayid = [2, 999999];",
              "const indexRNG = Math.floor(Math.random() * arrayid.length);",
              "pm.collectionVariables.set(\"petIdGet2\", arrayid[indexRNG]);",
              "console.log('[REQ-03 PRE] Buscando pet com ID:', arrayid[indexRNG]);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "try {",
              "    const status = pm.response.code;",
              "    ",
              "    if (status === 404) {",
              "        pm.test(\"✓ [REQ-03] GET retorna 404 para pet inexistente\", function () {",
              "            pm.response.to.have.status(404);",
              "        });",
              "    } else if (status === 200) {",
              "        pm.test(\"✓ [REQ-03] GET retorna 200 para pet existente\", function () {",
              "            pm.response.to.have.status(200);",
              "        });",
              "        ",
              "        const resposta = pm.response.json();",
              "        pm.test(\"✓ [REQ-03] Response contém ID\", function () {",
              "            pm.expect(resposta).to.have.property('id');",
              "        });",
              "    } else {",
              "        pm.test(\"✗ [REQ-03] Status inesperado: \" + status, function () {",
              "            pm.expect([200, 404]).to.include(status);",
              "        });",
              "    }",
              "} catch (e) {",
              "    pm.test(\"✗ [REQ-03] Erro ao processar response\", function () {",
              "        throw new Error('Erro: ' + e.message);",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{basePetURL}}/{{versao}}/pet/{{petIdGet2}}",
          "host": [
            "{{basePetURL}}"
          ],
          "path": [
            "{{versao}}",
            "pet",
            "{{petIdGet2}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "REQ-04 - Deletar Pet Criado",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Prepara o ID do pet para deletar",
              "try {",
              "    const meuBody = JSON.parse(pm.collectionVariables.get(\"meuBody\"));",
              "    pm.collectionVariables.set(\"petIdDelete\", meuBody.id);",
              "    console.log('[REQ-04 PRE] Preparado para deletar pet ID:', meuBody.id);",
              "} catch (e) {",
              "    console.error('[REQ-04 PRE] Erro ao preparar delete:', e.message);",
              "    pm.collectionVariables.set(\"petIdDelete\", null);",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "try {",
              "    const petIdDelete = pm.collectionVariables.get(\"petIdDelete\");",
              "    const status = pm.response.code;",
              "    ",
              "    if (petIdDelete && typeof petIdDelete !== 'undefined' && petIdDelete !== 'null') {",
              "        if (status === 200) {",
              "            pm.test(\"✓ [REQ-04] DELETE retorna 200 - Pet deletado com sucesso\", function () {",
              "                pm.response.to.have.status(200);",
              "            });",
              "        } else if (status === 404) {",
              "            pm.test(\"⚠ [REQ-04] DELETE retorna 404 - Pet não encontrado\", function () {",
              "                pm.response.to.have.status(404);",
              "            });",
              "        } else {",
              "            pm.test(\"✗ [REQ-04] DELETE retorna status inesperado: \" + status, function () {",
              "                pm.expect([200, 404]).to.include(status);",
              "            });",
              "        }",
              "    } else {",
              "        pm.test(\"⚠ [REQ-04] Pet ID não foi definido (REQ-01 pode ter falhado)\", function () {",
              "            // Não falha, apenas avisa",
              "            pm.expect(true).to.be.true;",
              "        });",
              "    }",
              "} catch (e) {",
              "    pm.test(\"✗ [REQ-04] Erro ao processar response\", function () {",
              "        throw new Error('Erro: ' + e.message);",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{basePetURL}}/{{versao}}/pet/{{petIdDelete}}",
          "host": [
            "{{basePetURL}}"
          ],
          "path": [
            "{{versao}}",
            "pet",
            "{{petIdDelete}}"
          ]
        }
      },
      "response": []
    }
