          "script": {
            "exec": [
              "const idarraytest = [2, pm.collectionVariables.get(\"petId\")];\r",
              "\r",
              "const idRNG = Math.floor(Math.random() * idarraytest.length);\r",
              "const petIdGet = idarraytest[idRNG];\r",
              "\r",
              "pm.collectionVariables.set(\"petIdGet\", petIdGet);"
            ],
