  "item": [
    {
      "name": "REQ-01",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const meuBody = JSON.parse(pm.collectionVariables.get(\"meuBody\"));\r",
              "\r",
              "const idRNG = meuBody.id;\r",
              "const nameRNG = meuBody.name;\r",
              "const statusRNG = meuBody.status;\r",
              "\r",
              "console.log(meuBody);\r",
              "\r",
              "const caminhoFeliz =\r",
              "    (typeof idRNG == 'number') &&\r",
              "    (typeof nameRNG == 'string') &&\r",
              "    (typeof statusRNG == 'string') && [\"available\", \"pending\", \"sold\"].includes(statusRNG);\r",
              "\r",
              "if (caminhoFeliz) {\r",
              "    pm.test(\"Post status 200 - Body Corretos\", function () {\r",
              "        pm.response.to.have.status(200);\r",
              "        pm.collectionVariables.set(\"InteraDel\", 0);\r",
              "    });\r",
              "} else if (typeof idRNG === 'string') {\r",
              "    pm.test(\"Post status 500 - Id como string\", function () {\r",
              "        pm.response.to.have.status(500);\r",
              "        pm.execution.setNextRequest(\"REQ-03\");\r",
              "    });\r",
              "}\r",
              "else {\r",
              "    pm.test(\"Post status 400 - Body Errado\", function () {\r",
              "        pm.response.to.have.status(400);\r",
              "    });\r",
              "}\r",
              "\r",
              "if (pm.response.code === 200) {\r",
              "    var resposta = pm.response.json();\r",
              "\r",
              "    pm.test(\"Body do Post com id e tipo do id corretos\", function () {\r",
              "        pm.expect(resposta.id).to.be.a('number');\r",
              "        pm.expect(resposta.id).to.eql(idRNG);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Body do Post com name e tipo name corretos\", function () {\r",
              "        pm.expect(resposta.name).to.be.a('string');\r",
              "        pm.expect(resposta.name).to.eql(nameRNG);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Body do Post com status e tipo do status corretos\", function () {\r",
              "        pm.expect(resposta.status).to.be.a('string');\r",
              "        pm.expect(resposta.status).to.eql(statusRNG);\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const idbase = [Math.floor(Math.random() * 10000), Math.floor(Math.random() * 10000), \"string\"];\r",
              "const namebase = [\"Pet\" + Math.floor(Math.random() * 10000),\"Pet\" + Math.floor(Math.random() * 10000), 1501];\r",
              "const statusbase = [\"available\", \"pending\", \"sold\", \"error\", 1];\r",
              "\r",
              "const indiceIdRNG = Math.floor(Math.random() * idbase.length);\r",
              "const indiceNameRNG = Math.floor(Math.random() * namebase.length);\r",
              "const indiceStatusRNG = Math.floor(Math.random() * statusbase.length);\r",
              "\r",
              "\r",
              "const meuBody ={\r",
              "    \"id\": idbase[indiceIdRNG],\r",
              "    \"name\": namebase[indiceNameRNG],\r",
              "    \"status\": statusbase[indiceStatusRNG]\r",
              "}\r",
              "\r",
              "pm.collectionVariables.set(\"meuBody\", JSON.stringify(meuBody));\r",
              "pm.collectionVariables.set(\"petId\", idbase[indiceIdRNG]);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{{meuBody}}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{basePetURL}}/{{versao}}/pet",
          "host": [
            "{{basePetURL}}"
          ],
          "path": [
            "{{versao}}",
            "pet"
          ]
        }
      },
      "response": []
    },
