          "script": {
            "exec": [
              "const meuBody = JSON.parse(pm.collectionVariables.get(\"meuBody\"));\r",
              "\r",
              "const idRNG = meuBody.id;\r",
              "const nameRNG = meuBody.name;\r",
              "const statusRNG = meuBody.status;\r",
              "\r",
              "const resposta = pm.response.json();\r",
              "\r",
              "console.log(resposta);\r",
              "\r",
              "const caminhofeliz = (resposta &&\r",
              "    resposta.id === idRNG &&\r",
              "    resposta.name === nameRNG &&\r",
              "    resposta.status === statusRNG);\r",
              "\r",
              "if (caminhofeliz) {\r",
              "    pm.test(\"Get status 200 - Dados iguais com o Post\", function () {\r",
              "        pm.response.to.have.status(200);\r",
              "    });\r",
              "\r",
              "    if (pm.response.code === 200) {\r",
              "        pm.test(\"Resposta do Get com id e tipo do id corretos\", function () {\r",
              "            pm.expect(resposta.id).to.be.a('number');\r",
              "            pm.expect(resposta.id).to.eql(idRNG);\r",
              "        });\r",
              "        pm.test(\"Resposta do Get com name e tipo do name corretos\", function () {\r",
              "            pm.expect(resposta.name).to.be.a('string');\r",
              "            pm.expect(resposta.name).to.eql(nameRNG);\r",
              "        });\r",
              "        pm.test(\"Resposta do Get com status e tipo do status corretos\", function () {\r",
              "            pm.expect(resposta.status).to.be.a('string');\r",
              "            pm.expect(resposta.status).to.eql(statusRNG);\r",
              "        });\r",
              "    }\r",
              "} else {\r",
              "    pm.test(\"Get status 200 com Dados diferentes do post\", function () {\r",
              "        pm.response.to.have.status(200);\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
